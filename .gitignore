# Excluding all transfer payloads but keeping the deny-PHP .htaccess.
# `Transfer Files/*` (rather than the directory itself) lets git
# descend in and apply the negation rule to the .htaccess file.
public/Transfer Files/*
!public/Transfer Files/.htaccess
